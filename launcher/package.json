{
  "name": "launcher",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "kill-port 5173 && vite",
    "electron": "cross-env ELECTRON_IS_DEV=1 electron .",
    "electron:prod": "electron .",
    "dev:electron": "concurrently -k -n vite,electron -c cyan,green \"npm run dev\" \"wait-on http-get://127.0.0.1:5173 && npm run electron\"",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "lint:fix": "node ./node_modules/eslint/bin/eslint.js . --fix",
    "format": "node ./node_modules/prettier/bin/prettier.cjs . --write",
    "format:check": "node ./node_modules/prettier/bin/prettier.cjs . --check",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:electron": "node --test electron/shell-profile.test.cjs electron/window-lifecycle.test.cjs electron/window-fullscreen-kiosk-guard.test.cjs electron/ipc-payload.test.cjs electron/ipc-contract.test.cjs electron/preload-bridge.test.cjs electron/web-shell-container.test.cjs electron/web-shell-profile.test.cjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "4.3.4",
    "@vitest/coverage-v8": "^4.1.3",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "jsdom": "^29.0.2",
    "kill-port": "2.0.1",
    "prettier": "^3.6.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.43.0",
    "vite": "5.4.21",
    "vitest": "^4.1.3",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@tanstack/react-query": "^5.96.2",
    "gsap": "^3.14.2",
    "iconoir-react": "^7.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  }
}
