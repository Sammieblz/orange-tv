    "kill-port": "2.0.1",
    "prettier": "^3.6.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.43.0",
    "vite": "5.4.21"
  },
  "dependencies": {
    "iconoir-react": "^7.11.0",
