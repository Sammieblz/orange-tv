root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Default to 2 spaces across the repo
indent_style = space
indent_size = 2

[*.md]
# If you rely on Markdown hard line breaks, adjust this.
trim_trailing_whitespace = true

[*.{cs,csx}]
indent_size = 4

[*.{json,yml,yaml}]
indent_size = 2

[*.{js,jsx,ts,tsx,cjs,mjs}]
indent_size = 2

