{
  "ORANGETV_API": {
    "Data": {
      "SqlitePath": ""
    }
  },
  "BrowserShell": {
    "Enabled": false,
    "LauncherUrl": "http://localhost:5173",
    "UseAppMode": true,
    "StartFullscreen": false,
    "ReadyTimeoutSeconds": 60,
    "ReadyPollIntervalMilliseconds": 1000
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
