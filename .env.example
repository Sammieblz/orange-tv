# Orange TV environment variables (examples only)
#
# Copy to `.env` for local overrides.
# Do NOT commit `.env` files.
#
# Conventions:
# - Backend (.NET): ORANGETV_API__Section__Key (double underscore maps to nested config)
# - Frontend (Vite): VITE_ORANGETV_* (Vite only exposes variables prefixed with VITE_)

# ---- Backend (.NET) ----
# Example: configure Kestrel URLs (optional; default comes from launchSettings.json / dotnet watch)
# ORANGETV_API__Urls=http://localhost:5144

# Example: SQLite DB location (choose a path per OS)
# Windows:
# ORANGETV_API__Data__SqlitePath=C:/Users/<you>/AppData/Local/OrangeTv/orange-tv.db
# Linux:
# ORANGETV_API__Data__SqlitePath=/var/lib/orange-tv/orange-tv.db

# Example: media file for seeded MPV launch when LaunchUrl is empty (Windows path example)
# ORANGETV_API__Launch__SampleMediaPath=C:/Videos/sample.mp4

# Optional: parent folder for Chrome --user-data-dir segments (when launcher.chrome.profilesRoot setting is unset)
# See docs/chrome-profiles-and-backup.md — do not confuse with ORANGETV_API__Data__SqlitePath
# ORANGETV_API__Launch__ChromeProfilesRoot=C:/OrangeTvProfiles

# Local media library (ffprobe/ffmpeg on PATH; see docs/media-library.md)
# ORANGETV_API__Library__Enabled=true
# ORANGETV_API__Library__ScanRoots__0=C:/Videos
# ORANGETV_API__Library__DebounceMilliseconds=3000

# Example: disable the dev Chromium shell auto-launch or point it at a custom browser path
# ORANGETV_API__BrowserShell__Enabled=false
# Ubuntu / Linux (use output of: command -v chromium || command -v google-chrome-stable)
# ORANGETV_API__BrowserShell__ExecutablePath=/usr/bin/chromium

# ---- Frontend (Vite) ----
# Example: API base URL used by the launcher UI
VITE_ORANGETV_API_BASE_URL=http://localhost:5144

# ---- Electron main process (not read by Vite; set in shell when launching Electron) ----
# Local API for launch IPC (POST /api/v1/launch); default http://localhost:5144
# ORANGETV_ELECTRON__API_BASE_URL=http://localhost:5144
# Window mode: omit or "default" = centered window; "appliance" = fullscreen TV-style shell
# ORANGETV_ELECTRON__SHELL_PROFILE=appliance
# Stricter kiosk mode (optional; use with appliance-style fullscreen)
# ORANGETV_ELECTRON__KIOSK=1
# Dev only: open DevTools when ELECTRON_IS_DEV=1 (never in appliance profile)
# ORANGETV_ELECTRON__OPEN_DEVTOOLS=1
# Dev server URL override (npm script sets ELECTRON_IS_DEV; this overrides loadURL target)
# VITE_DEV_SERVER_URL=http://127.0.0.1:5173
# Streaming tiles render as an in-window Electron BrowserView (no separate Chrome window, no
# taskbar entry) by default. Set to 0 or false to opt out and use the legacy external-Chrome
# path (spawns a real Chrome window via POST /api/v1/launch). See
# docs/player-and-streaming-strategy.md -> "Streaming shell - BrowserView wiring".
# ORANGETV_ELECTRON__WEB_SHELL_ENABLED=0
