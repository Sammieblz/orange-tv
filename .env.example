# Orange TV environment variables (examples only)
#
# Copy to `.env` for local overrides.
# Do NOT commit `.env` files.
#
# Conventions:
# - Backend (.NET): ORANGETV_API__Section__Key (double underscore maps to nested config)
# - Frontend (Vite): VITE_ORANGETV_* (Vite only exposes variables prefixed with VITE_)

# ---- Backend (.NET) ----
# Example: configure Kestrel URLs (optional; default comes from launchSettings.json / dotnet watch)
# ORANGETV_API__Urls=http://localhost:5144

# Example: SQLite DB location (choose a path per OS)
# Windows:
# ORANGETV_API__Data__SqlitePath=C:/Users/<you>/AppData/Local/OrangeTv/orange-tv.db
# Linux:
# ORANGETV_API__Data__SqlitePath=/var/lib/orange-tv/orange-tv.db

# ---- Frontend (Vite) ----
# Example: API base URL used by the launcher UI
VITE_ORANGETV_API_BASE_URL=http://localhost:5144

